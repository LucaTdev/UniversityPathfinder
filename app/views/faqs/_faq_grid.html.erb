<% faqs = Array(local_assigns.fetch(:faqs, [])) %>
<% mode = local_assigns.fetch(:mode, :visitor).to_sym %>
<% locale = local_assigns[:locale] %>
<% up_map = local_assigns.fetch(:up_map, {}) %>
<% down_map = local_assigns.fetch(:down_map, {}) %>
<% current_map = local_assigns.fetch(:current_map, {}) %>
<% empty_title = local_assigns[:empty_title] %>
<% empty_body = local_assigns[:empty_body] %>
<% collapse_id = local_assigns.fetch(:collapse_id, "faqs-more") %>
<% selected_locale = normalize_faq_locale(locale) %>
<% base_locale = Faq::BASE_LOCALE.to_s %>
<% show_translation_note = selected_locale.present? && selected_locale.split("-").first != base_locale %>

<% if faqs.empty? %>
  <%= render "empty_state", title: empty_title, body: empty_body %>
<% else %>
  <% if show_translation_note %>
    <% translated, untranslated = faqs.partition { |f| f.translation_for(selected_locale).present? } %>
    <% translated_collapse_id = "#{collapse_id}-translated" %>
    <% untranslated_collapse_id = "#{collapse_id}-untranslated" %>

      <div class="card-body">
        <% if translated.empty? %>
          <div class="text-muted">Nessuna FAQ disponibile in <%= faq_locale_label(selected_locale) %>.</div>
        <% else %>
          <% translated_visible = translated.first(9) %>
          <% translated_hidden = translated.drop(9) %>

          <div class="row">
            <% translated_visible.each do |faq| %>
              <%= render "faq_card",
                faq: faq,
                mode: mode,
                locale: locale,
                up_count: up_map[faq.id] || 0,
                down_count: down_map[faq.id] || 0,
                current_vote: current_map[faq.id] %>
            <% end %>
          </div>

          <% if translated_hidden.any? %>
            <div data-controller="faqs-show-more-less">
              <div class="text-center mt-2 mb-3">
                <button
                  data-faqs-show-more-less-target="button"
                  data-show-text="Mostra altro"
                  data-hide-text="Mostra meno"
                  class="btn btn-outline-secondary"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#<%= translated_collapse_id %>"
                  aria-expanded="false"
                  aria-controls="<%= translated_collapse_id %>"
                >
                  Mostra altro
                </button>
              </div>

              <div id="<%= translated_collapse_id %>" class="collapse mt-4" data-faqs-show-more-less-target="collapse">
                <div class="row">
                  <% translated_hidden.each do |faq| %>
                    <%= render "faq_card",
                      faq: faq,
                      mode: mode,
                      locale: locale,
                      up_count: up_map[faq.id] || 0,
                      down_count: down_map[faq.id] || 0,
                      current_vote: current_map[faq.id] %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

    <% if untranslated.any? %>
      <div class="alert alert-warning d-flex align-items-start justify-content-between gap-3" role="alert">
        <div class="d-flex align-items-start gap-2">
          <i class="fas fa-triangle-exclamation mt-1"></i>
          <div>
            <% if mode == :admin %>
              <div class="fw-semibold">FAQ da tradurre in <%= faq_locale_label(selected_locale) %></div>
              <div class="small">Queste FAQ verranno mostrate in <%= faq_locale_label(base_locale) %> finché non aggiungi la traduzione (pulsante “Traduzioni”).</div>
            <% else %>
              <div class="fw-semibold">FAQ non disponibili in <%= faq_locale_label(selected_locale) %></div>
              <div class="small">Queste FAQ sono mostrate in <%= faq_locale_label(base_locale) %>.</div>
            <% end %>
          </div>
        </div>
        <span class="badge text-bg-warning align-self-start"><%= untranslated.length %></span>
      </div>

      <% untranslated_visible = untranslated.first(9) %>
      <% untranslated_hidden = untranslated.drop(9) %>

      <div class="row">
        <% untranslated_visible.each do |faq| %>
          <%= render "faq_card",
            faq: faq,
            mode: mode,
            locale: locale,
            up_count: up_map[faq.id] || 0,
            down_count: down_map[faq.id] || 0,
            current_vote: current_map[faq.id] %>
        <% end %>
      </div>

      <% if untranslated_hidden.any? %>
        <div data-controller="faqs-show-more-less">
          <div class="text-center mt-2 mb-4">
            <button
              data-faqs-show-more-less-target="button"
              data-show-text="Mostra altro"
              data-hide-text="Mostra meno"
              class="btn btn-outline-secondary"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#<%= untranslated_collapse_id %>"
              aria-expanded="false"
              aria-controls="<%= untranslated_collapse_id %>"
            >
              Mostra altro
            </button>
          </div>

          <div id="<%= untranslated_collapse_id %>" class="collapse mt-4" data-faqs-show-more-less-target="collapse">
            <div class="row">
              <% untranslated_hidden.each do |faq| %>
                <%= render "faq_card",
                  faq: faq,
                  mode: mode,
                  locale: locale,
                  up_count: up_map[faq.id] || 0,
                  down_count: down_map[faq.id] || 0,
                  current_vote: current_map[faq.id] %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <% visible = faqs.first(9) %>
    <% hidden = faqs.drop(9) %>

    <div class="row">
      <% visible.each do |faq| %>
        <%= render "faq_card",
          faq: faq,
          mode: mode,
          locale: locale,
          up_count: up_map[faq.id] || 0,
          down_count: down_map[faq.id] || 0,
          current_vote: current_map[faq.id] %>
      <% end %>
    </div>

    <% if hidden.any? %>
      <div data-controller="faqs-show-more-less">
        <div class="text-center mt-2 mb-4">
          <button
            data-faqs-show-more-less-target="button"
            data-show-text="Mostra altro"
            data-hide-text="Mostra meno"
            class="btn btn-outline-secondary"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#<%= collapse_id %>"
            aria-expanded="false"
            aria-controls="<%= collapse_id %>"
          >
            Mostra altro
          </button>
        </div>

        <div id="<%= collapse_id %>" class="collapse mt-4" data-faqs-show-more-less-target="collapse">
          <div class="row">
            <% hidden.each do |faq| %>
              <%= render "faq_card",
                faq: faq,
                mode: mode,
                locale: locale,
                up_count: up_map[faq.id] || 0,
                down_count: down_map[faq.id] || 0,
                current_vote: current_map[faq.id] %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
