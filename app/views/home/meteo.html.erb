<% end %>
<%= javascript_include_tag 'news_management' %>

    <div class="main-grid">
        <!-- Widget Meteo -->
        <div class="widget weather-widget">
            <div class="widget-header" style="background: linear-gradient(135deg, #89f7fe 0%, #66a6ff 100%); color: white; border-radius: 12px 12px 0 0;">
                <div class="container weather-panel">
                    <h1 class="text-center mb-4 weather-panel-title">Previsioni Meteo</h1>
                    <div id="meteo-card" class="card shadow-sm p-4 text-center">
                        <p>Caricamento posizione...</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Widget Notifiche Meteo -->
        <div class="widget weather-notifications-widget">
            <div class="widget-header" style="background: linear-gradient(135deg, #e17055, #f39c12); color: white; border-radius: 12px 12px 0 0;">
                <h3 class="widget-title">
                    <i class="fas fa-bell"></i>
                    Notifiche Meteo
                </h3>
                <span class="widget-count-badge">2 attive</span>
            </div>
            <div class="widget-body widget-body--scroll widget-body--alerts">
                <div class="widget-body-inner">
                    <div id="weather-alerts" class="p-3 card shadow-sm">
                        <p>Caricamento allerte...</p>
                    </div>
                </div>
            </div>
            <div class="widget-footer">
                <small style="color: #666;">Notifiche attive - Sistema di allerta automatico</small>
            </div>
        </div>
    </div>
</div>
        </div>
    </div>

<script>
function initializeMeteo() {
    const meteoCard = document.getElementById('meteo-card');
    
    // Evita inizializzazioni multiple
    if (!meteoCard) {
        console.log('Meteo card non trovato');
        return;
    }
    
    if (meteoCard.dataset.initialized === 'true') {
        console.log('Meteo già inizializzato');
        return;
    }
    
    console.log('Inizializzazione meteo...');
    meteoCard.dataset.initialized = 'true';

    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(success, error);
    } else {
        meteoCard.innerHTML = "<div class='alert alert-danger'>Geolocalizzazione non supportata dal browser.</div>";
    }

    function success(position) {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;

        // Fetch dati meteo attuale
        fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&hourly=temperature_2m,weathercode,relativehumidity_2m,pressure_msl&current_weather=true&timezone=auto`)
        .then(response => response.json())
        .then(data => {
            const weather = data.current_weather;
            const temp = weather.temperature;
            const wind = weather.windspeed;
            const code = weather.weathercode;
            const time = weather.time;

            // Trova indice dell'orario corrente
            const currentIndex = data.hourly.time.indexOf(time);
            const humidity = data.hourly.relativehumidity_2m[currentIndex];
            const pressure = data.hourly.pressure_msl[currentIndex];

            const descrizione = getWeatherDescription(code);
            const icona = getWeatherIcon(code);

            meteoCard.innerHTML = `
            <div class="d-flex flex-column align-items-center">
                <img src="${icona}" alt="Icona Meteo" class="mb-3" style="width:80px;">
                <h2 class="mb-3">${descrizione}</h2>
                <p class="fs-4"><strong>Temperatura:</strong> ${temp}°C</p>
                <p><strong>Umidità:</strong> ${humidity}%</p>
                <p><strong>Pressione:</strong> ${pressure} hPa</p>
                <p><strong>Vento:</strong> ${wind} km/h</p>
                <p class="text-muted"><small>Aggiornato alle: ${time}</small></p>
            </div>
            `;
        })
        .catch(err => {
            meteoCard.innerHTML = "<div class='alert alert-danger'>Errore nel recupero dei dati meteo.</div>";
            console.error(err);
        });

        // Fetch allerte meteo
        getWeatherAlerts(lat, lon);
    }

    function error() {
        meteoCard.innerHTML = "<div class='alert alert-warning'>Impossibile ottenere la posizione.</div>";
        const alertsContainer = document.getElementById('weather-alerts');
        if (alertsContainer) {
            alertsContainer.innerHTML = '<div class="alert alert-warning">Allerte non disponibili senza posizione.</div>';
        }
    }

    function getWeatherDescription(code) {
        const map = {
        0: "Cielo sereno", 1: "Prevalentemente sereno", 2: "Parzialmente nuvoloso", 3: "Nuvoloso",
        45: "Nebbia", 48: "Nebbia ghiacciata", 51: "Pioviggine leggera", 53: "Pioviggine moderata",
        55: "Pioviggine intensa", 61: "Pioggia leggera", 63: "Pioggia moderata", 65: "Pioggia intensa",
        71: "Neve leggera", 73: "Neve moderata", 75: "Neve intensa", 80: "Rovesci leggeri",
        81: "Rovesci moderati", 82: "Rovesci forti", 95: "Temporali", 96: "Temporali con grandine leggera",
        99: "Temporali con grandine forte"
        };
        return map[code] || "Condizione sconosciuta";
    }

    function getWeatherIcon(code) {
        if ([0, 1].includes(code)) return "https://img.icons8.com/color/96/000000/sun--v1.png";
        if ([2, 3].includes(code)) return "https://img.icons8.com/color/96/000000/partly-cloudy-day.png";
        if ([61, 63, 65, 80, 81, 82].includes(code)) return "https://img.icons8.com/color/96/000000/rain.png";
        if ([71, 73, 75].includes(code)) return "https://img.icons8.com/color/96/000000/snow.png";
        if ([95, 96, 99].includes(code)) return "https://img.icons8.com/color/96/000000/storm.png";
        return "https://img.icons8.com/color/96/000000/cloud.png";
    }

    function getWeatherAlerts(lat, lon) {
        const alertsContainer = document.getElementById('weather-alerts');
        if (!alertsContainer) return;
        
        fetch(`https://api.open-meteo.com/v1/weather-alerts?latitude=${lat}&longitude=${lon}`)
        .then(response => response.json())
        .then(data => {
            if (data.alerts && data.alerts.length > 0) {
                let html = '';
                data.alerts.forEach(alert => {
                    html += `
                    <div class="alert alert-warning mb-3">
                        <strong>${alert.event}</strong><br>
                        <small><em>${alert.sender_name}</em></small><br>
                        <span>${alert.description}</span><br>
                        <small><strong>Validità:</strong> ${alert.effective} - ${alert.expires}</small>
                    </div>
                    `;
                });
                alertsContainer.innerHTML = html;
            } else {
                alertsContainer.innerHTML = '<div class="alert alert-success">Nessuna allerta meteo in corso.</div>';
            }
        })
        .catch(err => {
            alertsContainer.innerHTML = '<div class="alert alert-danger">Errore nel recupero delle allerte.</div>';
            console.error(err);
        });
    }
}

// Ascolta tutti gli eventi possibili
if (document.readyState === 'loading') {
    document.addEventListener("DOMContentLoaded", initializeMeteo);
} else {
    initializeMeteo();
}
if (!window.meteoListenersBound) {
    document.addEventListener("turbo:load", initializeMeteo);
    document.addEventListener("turbo:render", initializeMeteo);
    window.meteoListenersBound = true;
}
</script>
